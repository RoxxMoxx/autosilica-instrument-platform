# AutoSilica Instrument Platform - environment variables
# Copy this file to .env and adjust values as needed.

# Selects config/{APP_ENV}.toml as an overlay on config/default.toml
APP_ENV=development

# Overrides follow the pattern AUTOSILICA__<SECTION>__<KEY>
AUTOSILICA__SERVER__HOST=0.0.0.0
AUTOSILICA__SERVER__PORT=8080
AUTOSILICA__LOGGING__LEVEL=debug
